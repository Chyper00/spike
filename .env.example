WALLET_PRIVATE_KEY=your_private_key_here
PORT=3000
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
ALCHEMY_URL=
# Relayer (claim/withdraw): opcional; default no código é v2 → v1.
# POLYMARKET_RELAYER_PRIMARY=https://relayer-v2.polymarket.com
# POLYMARKET_RELAYER_FALLBACK=https://relayer.polymarket.com/api/v1
# Se /api/redeem/create retornar 400, tente Origin do site:
# POLYMARKET_REDEEM_ORIGIN=https://polymarket.com
RELAYER_URL=https://relayer-v2.polymarket.com
RELAYER_TX_TYPE=SAFE
POLYMARKET_USER=
# Opcional: autenticação alternativa no /submit (HMAC). Se preencher, não precisa de RELAYER_API_KEY*.
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=